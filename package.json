    "dotenv": "^17.4.2",
    "express": "^5.0.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "vite": "^6.4.2"
  }
